---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, serviceFamilies } from '../../data/siteData.js';
---
<BaseLayout title={'Services | ' + site.title} description={'All services from ' + site.business + ' in Frederick, Maryland.'} canonicalPath="/services/">
  <section class="page-head"><h1>{site.business} Services</h1><p>{site.sub}</p></section>
  <section class="section"><div class="cards">{serviceFamilies.map((family) => <a class="card" href={`/services/${family.slug}/`}><h3>{family.name}</h3><p>{family.shortDescription}</p></a>)}</div></section>
</BaseLayout>