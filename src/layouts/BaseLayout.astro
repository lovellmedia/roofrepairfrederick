---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import '../styles/theme.css';
const { title, description, canonicalPath = Astro.url.pathname, image = '/images/hero.png' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} canonicalPath={canonicalPath} image={image} />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
  </body>
</html>
